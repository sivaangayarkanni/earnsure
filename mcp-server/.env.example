NODE_ENV=development
DATABASE_URL=postgres://earnsure:earnsure_dev_password@localhost:5432/earnsure
LOG_LEVEL=info
OPENWEATHER_API_KEY=your_openweather_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5/weather
RISK_PREDICTION_URL=http://localhost:8000/risk/predict
FRAUD_MODEL_URL=http://localhost:8000/fraud/score
FRAUD_SCORE_THRESHOLD=0.6
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=earnsure-app
UPI_PROVIDER=simulate
UPI_DEFAULT_VPA=worker@upi
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_ACCOUNT_NUMBER=your_razorpay_account
POOL_RESERVE_PERCENT=0.1
POOL_PAYOUT_CAP_PERCENT=0.4
ALLOW_RESERVE_PAYOUT=true
REINSURANCE_ENABLED=true
REINSURANCE_SEED_BALANCE=50000
